#!/bin/bash

TERMINAL="ghostty"
WORKSPACE="special:magic"

kill_showoff() {
  hyprctl dispatch submap reset

  if pgrep -f "$TERMINAL --class=magic-dash" >/dev/null; then
    hyprctl dispatch togglespecialworkspace magic
    sleep 0.1

    # Kill the Wayland terminal client
    pkill -f "$TERMINAL --class=magic-dash"

    # Explicitly destroy the tmux session and all background child processes
    tmux kill-session -t showoff 2>/dev/null

    pkill -f "showoff_watcher"
  fi
  exit 0
}

# 1. Handle Explicit Kill Flag
if [[ "$1" == "--kill" ]]; then
  kill_showoff
fi

# 2. Handle Existing Processes
if pgrep -f "$TERMINAL --class=magic-dash" >/dev/null; then
  if [[ "$1" == "--idle" ]]; then
    # If triggered by idle but processes are already running, abort to prevent overlap
    exit 0
  else
    # If triggered by hotkey and processes are running, toggle them off
    kill_showoff
  fi
fi

# 3. Spawn a single process utilizing the Hyprland dwindle/master default allocation
hyprctl dispatch exec "[workspace $WORKSPACE] $TERMINAL --class=magic-dash --background-opacity=0.7 -e bash -c '/home/$USER/.local/bin/magic-layout'"

# 4. Render Polling
for i in {1..20}; do
  if hyprctl clients -j | jq -e '.[] | select(.workspace.name == "'"$WORKSPACE"'")' >/dev/null; then
    IS_VISIBLE=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .specialWorkspace.name')
    if [ "$IS_VISIBLE" != "$WORKSPACE" ]; then
      hyprctl dispatch togglespecialworkspace magic
    fi
    break
  fi
  sleep 0.1
done

# 5. Global Input Interception (Hotkey & Idle)
hyprctl dispatch submap showoff_idle

(
  exec -a showoff_watcher bash -c '
    # 500ms delay prevents the physical release of the Super+S hotkey from triggering an instant kill
    sleep 0.5 
    INITIAL_POS=$(hyprctl cursorpos)
    
    while true; do
        CURRENT_POS=$(hyprctl cursorpos)
        if [ "$INITIAL_POS" != "$CURRENT_POS" ]; then
            $HOME/.local/bin/showoff --kill
            exit 0
        fi
        sleep 0.1 
    done
    '
) &
disown
