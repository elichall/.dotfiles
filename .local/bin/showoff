#!/bin/bash

TERMINAL="ghostty"
WORKSPACE="special:magic"

kill_showoff() {
  # 1. Instantly restore normal compositor keybinds
  hyprctl dispatch submap reset

  if pgrep -f "$TERMINAL --class=magic-" >/dev/null; then
    hyprctl dispatch togglespecialworkspace magic
    sleep 0.1
    pkill -f "$TERMINAL --class=magic-"
    pkill -f "showoff_watcher"
  fi
  exit 0
}

# Strict Argument Routing
if [[ "$1" == "--kill" ]]; then
  kill_showoff
elif [[ -z "$1" ]]; then
  # Hotkey Behavior
  if pgrep -f "$TERMINAL --class=magic-" >/dev/null; then
    kill_showoff
  fi
elif [[ "$1" == "--idle" ]]; then
  # Idle Behavior
  if pgrep -f "$TERMINAL --class=magic-" >/dev/null; then
    exit 0
  fi
else
  exit 0
fi

# Spawn Processes with Synchronous Geometry Rules
hyprctl dispatch exec "[workspace $WORKSPACE; float; size 600 450; move 10 10] $TERMINAL --class=magic-fastfetch -e sh -c 'fastfetch && sleep infinity'"
hyprctl dispatch exec "[workspace $WORKSPACE; float; size 1280 450; move 630 10] $TERMINAL --class=magic-btop -e btop"
hyprctl dispatch exec "[workspace $WORKSPACE; float; size 600 600; move 10 470] $TERMINAL --class=magic-cava -e cava"
hyprctl dispatch exec "[workspace $WORKSPACE; float; size 1280 600; move 630 470] $TERMINAL --class=magic-rotator -e bash -c '/home/$USER/.local/bin/term-rotator'"

# Dynamic Polling: Wait for Wayland to map at least one window
for i in {1..20}; do
  if hyprctl clients -j | jq -e '.[] | select(.workspace.name == "'"$WORKSPACE"'")' >/dev/null; then
    IS_VISIBLE=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true) | .specialWorkspace.name')
    if [ "$IS_VISIBLE" != "$WORKSPACE" ]; then
      hyprctl dispatch togglespecialworkspace magic
    fi
    break
  fi
  sleep 0.1
done

# IDLE WATCHER DAEMON & COMPOSITOR LOCK
if [[ "$1" == "--idle" ]]; then
  # Lock keyboard and click input at the Wayland protocol level
  hyprctl dispatch submap showoff_idle

  # Fork high-frequency mouse coordinate watcher
  (
    exec -a showoff_watcher bash -c '
        sleep 0.5 # Allow physical mouse to settle from taking hands off
        INITIAL_POS=$(hyprctl cursorpos)
        while true; do
            CURRENT_POS=$(hyprctl cursorpos)
            if [ "$INITIAL_POS" != "$CURRENT_POS" ]; then
                $HOME/.local/bin/showoff --kill
                exit 0
            fi
            sleep 0.1 # Snappy 100ms evaluation loop
        done
        '
  ) &
  disown
fi
