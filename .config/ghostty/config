font-family = JetBrainsMono Nerd Font
font-family = "Noto Sans Mono CJK JP"

font-size = 13
theme = "IC Green PPL"
window-decoration = false
cursor-style = block

background-opacity = 0.90
background-blur-radius = 20

# disable fancy features
font-feature = -calt
font-feature = -liga
font-feature = -dlig

# Optimization: Ensures Wayland native protocol 
command = /usr/bin/bash

confirm-close-surface = false

# Sourced dynamically by the global theme engine switcher
config-file = ?~/.config/ghostty/active_theme

# Force Ctrl+Enter to act as a raw, immediate execution line-feed
keybind = ctrl+enter=text:\r
