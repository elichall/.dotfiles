set -g status-style "bg=#292522,fg=#ece1d7"
set -g status-left "#[fg=#292522,bg=#78997a,bold] 󰨖 #S #[bg=default,fg=default] "
set -g status-right "#[fg=#867462,bg=default]󰇄 #H "
set -g window-status-format "#[fg=#867462,bg=default] #I:#W "
set -g window-status-current-format "#[fg=#78997a,bg=#867462,bold] #I:#W "
set -g window-status-separator ""
set -g pane-border-style "fg=#867462"
set -g pane-active-border-style "fg=#78997a"
set -g message-style "bg=#867462,fg=#78997a,bold"
